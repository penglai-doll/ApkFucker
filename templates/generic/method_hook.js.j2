Java.perform(function() {
    var TargetClass = Java.use("{{ className }}");
    var Log = Java.use("android.util.Log");
    var Exception = Java.use("java.lang.Exception");
    var methodName = "{{ methodName }}";

    function stringify(value) {
        if (value === null || value === undefined) {
            return "null";
        }
        try {
            return value.toString();
        } catch (error) {
            return "<toString failed: " + error + ">";
        }
    }

    TargetClass[methodName].overloads.forEach(function(overload, overloadIndex) {
        overload.implementation = function() {
            var argsArray = [];
            for (var index = 0; index < arguments.length; index++) {
                argsArray.push(stringify(arguments[index]));
            }
            send(JSON.stringify({
                "event_type": "method_call",
                "hook_type": "method",
                "class_name": "{{ className }}",
                "method_name": methodName,
                "overload_index": overloadIndex,
                "arguments": argsArray,
                "stacktrace": Log.getStackTraceString(Exception.$new())
            }));
            try {
                var ret = overload.apply(this, arguments);
                send(JSON.stringify({
                    "event_type": "method_return",
                    "hook_type": "method",
                    "class_name": "{{ className }}",
                    "method_name": methodName,
                    "overload_index": overloadIndex,
                    "return_value": stringify(ret)
                }));
                return ret;
            } catch (error) {
                send(JSON.stringify({
                    "event_type": "method_error",
                    "hook_type": "method",
                    "class_name": "{{ className }}",
                    "method_name": methodName,
                    "overload_index": overloadIndex,
                    "return_value": stringify(error)
                }));
                throw error;
            }
        };
    });
});
